{
  "openapi": "3.0.3",
  "info": {
    "title": "Adjudication Agent",
    "description": "Applies benefit rules to validated claims — checks coverage, compares billed vs allowed amount, enforces prior authorisation, and routes to APPROVED, REJECTED, or PENDING_REVIEW.",
    "version": "0.1.0"
  },
  "servers": [
    {
      "url": "http://localhost:9091",
      "description": "Local development"
    }
  ],
  "paths": {
    "/adjudicationAgent/chat": {
      "post": {
        "summary": "Submit a message to the Adjudication Agent",
        "operationId": "adjudicationAgentChat",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChatReqMessage"
              },
              "example": {
                "sessionId": "session-abc123",
                "message": "Adjudicate claim CLM-A001 for member M-1001 on plan PLAN-GOLD, procedure 99213, billed $130"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created — agent response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChatRespMessage"
                },
                "example": {
                  "message": "Claim CLM-A001 is APPROVED. Procedure 99213 is covered under PLAN-GOLD with an allowed amount of $150. Billed amount $130 is within limit. No prior authorisation required."
                }
              }
            }
          },
          "400": {
            "description": "Bad request — malformed payload",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorPayload"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorPayload"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ChatReqMessage": {
        "type": "object",
        "required": ["sessionId", "message"],
        "properties": {
          "sessionId": {
            "type": "string",
            "description": "Session identifier for multi-turn conversations."
          },
          "message": {
            "type": "string",
            "description": "Natural language message to the agent describing the claim to adjudicate."
          }
        },
        "additionalProperties": false
      },
      "ChatRespMessage": {
        "type": "object",
        "required": ["message"],
        "properties": {
          "message": {
            "type": "string",
            "description": "Agent's natural language response including adjudication decision (APPROVED / REJECTED / PENDING_REVIEW) and rationale."
          }
        },
        "additionalProperties": false
      },
      "ErrorPayload": {
        "type": "object",
        "required": ["timestamp", "status", "reason", "message", "path", "method"],
        "properties": {
          "timestamp": {
            "type": "string",
            "description": "Time when the error occurred."
          },
          "status": {
            "type": "integer",
            "format": "int64",
            "description": "HTTP status code associated with the error."
          },
          "reason": {
            "type": "string",
            "description": "Short reason for the error."
          },
          "message": {
            "type": "string",
            "description": "Detailed message describing the error."
          },
          "path": {
            "type": "string",
            "description": "Request path where the error occurred."
          },
          "method": {
            "type": "string",
            "description": "HTTP method used for the request."
          }
        },
        "additionalProperties": false
      }
    }
  }
}